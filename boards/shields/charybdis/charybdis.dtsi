#include <dt-bindings/zmk/matrix_transform.h>
#include <dt-bindings/input/input-event-codes.h>
#include <dt-bindings/zmk/input_transform.h>
#include <input/processors.dtsi>

/ {
    chosen {
        zmk,kscan = &kscan0;
        zmk,matrix_transform = &five_column_transform;
        zmk,battery = &vbatt;
    };

    vbatt: vbatt {
	    compatible = "zmk,battery-nrf-vddh";
    };

    five_column_transform: keymap_transform_0 {
        compatible = "zmk,matrix-transform";
        columns = <10>;
        rows = <4>;

        map = <
	RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4)  RC(0,5) RC(0,6) RC(0,7) RC(0,8) RC(0,9)
	RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4)  RC(1,5) RC(1,6) RC(1,7) RC(1,8) RC(1,9)
	RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4)  RC(2,5) RC(2,6) RC(2,7) RC(2,8) RC(2,9)
					RC(3,2) RC(3,3) RC(3,4)  RC(3,5) RC(3,6)
        >;
    };

    kscan0: kscan {
        compatible = "zmk,kscan-gpio-matrix";

        diode-direction = "col2row";
		row-gpios
			= <&pro_micro 21 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&pro_micro 18 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&pro_micro 5 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
			, <&pro_micro 4 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;
        wakeup-source;
    };

    // ZMK 공식 split pointing 패턴
    // peripheral(right)이 trackball_split에 실제 device를 연결하면
    // split BLE를 통해 central(dongle)의 trackball_listener로 이벤트가 forwarding된다.
    // listener는 기본 disabled 상태이며 central overlay에서 활성화.
    split_inputs {
        #address-cells = <1>;
        #size-cells = <0>;

        trackball_split: trackball_split@0 {
            compatible = "zmk,input-split";
            reg = <0>;
            // peripheral은 device 연결하면서 status=okay,
            // central(dongle)도 GATT char 수신을 위해 status=okay 활성화 필요.
            // left처럼 둘 다 아닌 빌드는 disabled 상태라 service.c iteration에서 제외됨.
            status = "disabled";
        };
    };

    trackball_listener: trackball_listener {
        compatible = "zmk,input-listener";
        status = "disabled";
        device = <&trackball_split>;

        scroller {
            layers = <7>;  // SCR 레이어
            // 매퍼가 X→HWHEEL, Y→WHEEL로 바꾼 뒤 vertical만 부호 반전 (자연 스크롤)
            input-processors =
                <&zip_x_scaler 1 25>,
                <&zip_y_scaler 1 30>,
                <&zip_xy_to_scroll_mapper>,
                <&zip_scroll_transform INPUT_TRANSFORM_X_INVERT>;
        };

        sniper {
            layers = <8>;  // SNI 레이어
            input-processors = <&zip_xy_scaler 1 3>;  // 1/3 속도
        };
    };
};
